"fact.length.meter.title" = "What the meter really is";
"fact.length.meter.body" = "Since 1983 the meter is defined as the distance light travels in vacuum during 1/299,792,458 of a second.";
"fact.length.lightYear.title" = "One light-year";
"fact.length.lightYear.body" = "About 9.46 trillion kilometers — the distance light covers in a Julian year.";
"fact.mass.kilogram.title" = "Kilogram redefined";
"fact.mass.kilogram.body" = "In 2019 the kilogram was redefined from a physical artifact (the IPK) to Planck's constant — universal and immutable.";
"fact.mass.troyOunce.title" = "Troy vs avoirdupois";
"fact.mass.troyOunce.body" = "A troy ounce (~31.10 g) is used for precious metals and is heavier than a regular ounce (~28.35 g).";
"fact.temperature.celsius.title" = "Anders Celsius's flip";
"fact.temperature.celsius.body" = "Celsius originally proposed a reversed scale (0 = boiling, 100 = freezing). It was inverted to today's form after his death in 1744.";
"fact.temperature.absolute.title" = "Why 273.15";
"fact.temperature.absolute.body" = "Absolute zero — 0 K, −273.15 °C — is where classical kinetic motion of particles stops.";
"fact.volume.liter.title" = "Liter is non-SI";
"fact.volume.liter.body" = "The liter is accepted for use with SI but isn't itself an SI unit — the SI unit of volume is the cubic meter.";
"fact.volume.gallons.title" = "US vs imperial gallons";
"fact.volume.gallons.body" = "A US gallon is 3.785 L; an imperial gallon is 4.546 L — about 20% larger.";
"fact.area.hectare.title" = "A hectare is a square 100 m";
"fact.area.hectare.body" = "Exactly 10,000 m² — roughly two soccer fields.";
"fact.speed.mach.title" = "Mach is relative";
"fact.speed.mach.body" = "Mach 1 depends on temperature: ~1235 km/h at sea level but drops at altitude.";
"fact.data.byte.title" = "Byte isn't always 8 bits";
"fact.data.byte.body" = "Modern bytes are 8 bits, but historic machines used 6-, 7- or 9-bit bytes. The 8-bit byte became standard around the 1970s.";
"fact.time.second.title" = "Atomic second";
"fact.time.second.body" = "Defined by 9,192,631,770 transitions of caesium-133 — accurate to one second in millions of years.";
"fact.pressure.bar.title" = "One bar ≈ surface pressure";
"fact.pressure.bar.body" = "1 bar = 100,000 Pa, very close to average atmospheric pressure at sea level (1.01325 bar).";
"fact.energy.joule.title" = "Joule, the workhorse";
"fact.energy.joule.body" = "1 J is the energy to lift ~102 g by one meter against gravity, or the heat from 0.239 calories.";
"fact.power.watt.title" = "Watt = J/s";
"fact.power.watt.body" = "Power is the rate of energy transfer. A 100 W bulb burns 100 J every second.";
"fact.frequency.hertz.title" = "Hz vs RPM";
"fact.frequency.hertz.body" = "60 Hz = 3,600 rpm. Mains electricity is 50 Hz in Europe, 60 Hz in the Americas.";
"fact.fuel.lp100.title" = "Lower is better";
"fact.fuel.lp100.body" = "L/100 km is reciprocal to mpg — small numbers mean efficient cars. 5 L/100 km ≈ 47 mpg (US).";
"fact.angle.radian.title" = "Why radians";
"fact.angle.radian.body" = "A radian is the angle subtended by an arc equal to the radius — π rad in a half-turn, 2π rad in a full circle.";

